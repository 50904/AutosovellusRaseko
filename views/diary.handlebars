<div class="container">
    <h1>Kaikki ajot</h1>
    <p>Seuraavasta taulukosta näkyy kaikkien autojen ajot</p>

    <table>
        <tr>
            <th>Auto</th>
            <th>Kuljettaja</th>
            <th>Tarkoitus</th>
            <th>Lähtö</th>
            <th>Paluu</th>
        </tr>
        {{#each diaryData}}
        <tr class="tr-highlighted">
            <td>{{rekisterinumero}}</td>
            <td>{{nimi}}</td>
            <td>{{tarkoitus}}</td>
            <td>{{otettu}}</td>
            <td>{{palautettu}}</td>
        </tr>
        {{/each}}
    </table>
</div>