<body>
    {{> menu}}
    <div class="container">
        <div id="map">
            <h1 id="register" class="modern-header">{{register}}</h1>

            <div id="routeInfo" class="alignment-box"></div>

            {{!-- It is very important to define height for the map and give a id for it --}}
            <div class="map-frame" id="mapid"></div>

            <script>
                const formatDateTime = (value) => {
                    if (!value) {
                        return 'Ei tietoja';
                    }

                    return new Date(value).toLocaleString('fi-FI');
                };

                const loadLocationData = async () => {
                    const params = new URLSearchParams(window.location.search);
                    const register = document.getElementById('register').innerHTML.trim();
                    const deviceId = params.get('deviceId') || register;

                    const response = await fetch('/api/deviceLocation?deviceId=' + encodeURIComponent(deviceId));

                    if (!response.ok) {
                        const errorText = await response.text();
                        document.getElementById('routeInfo').innerHTML = '<p>Paikannushaku epäonnistui: ' + response.status + '</p><pre>' + errorText + '</pre>';
                        return;
                    }

                    const location = await response.json();

                    if (!location || location.lat == null || location.lon == null) {
                        document.getElementById('routeInfo').innerHTML = '<p>Sijaintitietoja ei löytynyt.</p>';
                        return;
                    }

                    document.getElementById('routeInfo').innerHTML = `
                        <div class="drive-information">
                            <p><strong>Ajoneuvo:</strong> ${location.deviceName || register}</p>
                            <p><strong>Leveysaste:</strong> ${location.lat}</p>
                            <p><strong>Pituusaste:</strong> ${location.lon}</p>
                            <p><strong>Aikaleima:</strong> ${formatDateTime(location.timestamp)}</p>
                            <p><strong>Nimetty paikka:</strong> ${(location.namedLocations || []).map(item => item.name).filter(Boolean).join(', ') || 'Ei nimettyä paikkaa'}</p>
                        </div>
                    `;

                    const rasekomap = L.map('mapid').setView([location.lat, location.lon], 16);

                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        attribution: 'Map data © <a href="https://openstreetmap.org">OpenStreetMap</a> contributors',
                        maxZoom: 19,
                    }).addTo(rasekomap);

                    L.marker([location.lat, location.lon]).addTo(rasekomap).bindPopup(location.deviceName || register).openPopup();
                };

                loadLocationData();
            </script>
        </div>
    </div>
</body>