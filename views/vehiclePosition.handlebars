<body>
    {{> menu}}
    <div class="container">
        <div id="map">
            <h1 id="register" class="modern-header">{{register}}</h1>

            <div id="routeInfo" class="alignment-box"></div>

            {{!-- It is very important to define height for the map and give a id for it --}}
            <div class="map-frame" id="mapid"></div>

            <script>
                const formatAddress = (position) => {
                    if (!position) {
                        return 'Ei tietoja';
                    }

                    const parts = [position.street, position.houseno, position.city].filter(Boolean);
                    return parts.join(', ');
                };

                const formatDateTime = (value) => {
                    if (!value) {
                        return 'Ei tietoja';
                    }

                    return new Date(value).toLocaleString('fi-FI');
                };

                const loadRouteData = async () => {
                    const params = new URLSearchParams(window.location.search);
                    const register = document.getElementById('register').innerHTML.trim();
                    const deviceId = params.get('deviceId') || register;

                    const now = new Date();
                    const startDefault = new Date(now.getTime() - 24 * 60 * 60 * 1000).toISOString();
                    const endDefault = now.toISOString();

                    const startTime = params.get('startTime') || startDefault;
                    const endTime = params.get('endTime') || endDefault;

                    const apicall = '/api/deviceRoutes?deviceId=' + encodeURIComponent(deviceId) + '&startTime=' + encodeURIComponent(startTime) + '&endTime=' + encodeURIComponent(endTime);
                    const response = await fetch(apicall);

                    if (!response.ok) {
                        const errorText = await response.text();
                        document.getElementById('routeInfo').innerHTML = '<p>API-kutsu epäonnistui: ' + response.status + '</p><pre>' + errorText + '</pre>';
                        return;
                    }

                    const routes = await response.json();
                    const route = Array.isArray(routes) ? routes[0] : routes;

                    if (!route) {
                        document.getElementById('routeInfo').innerHTML = '<p>Reittitietoja ei löytynyt.</p>';
                        return;
                    }

                    document.getElementById('routeInfo').innerHTML = `
                        <div class="drive-information">
                            <p><strong>Lähtöosoite:</strong> ${formatAddress(route.routeStartPosition)}</p>
                            <p><strong>Paluuosoite:</strong> ${formatAddress(route.routeStopPosition)}</p>
                            <p><strong>Lähtöaika:</strong> ${formatDateTime(route.driveStartTimest)}</p>
                            <p><strong>Paluuaika:</strong> ${formatDateTime(route.driveStopTimest)}</p>
                        </div>
                    `;

                    const points = Array.isArray(route.points) ? route.points.filter(point => point.lat != null && point.lon != null) : [];

                    if (!points.length) {
                        return;
                    }

                    const mapPoints = points.map(point => [point.lat, point.lon]);
                    const rasekomap = L.map('mapid').setView(mapPoints[0], 16);

                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        attribution: 'Map data © <a href="https://openstreetmap.org">OpenStreetMap</a> contributors',
                        maxZoom: 19,
                    }).addTo(rasekomap);

                    const routeLine = L.polyline(mapPoints, { color: '#0b5cab', weight: 4 }).addTo(rasekomap);
                    rasekomap.fitBounds(routeLine.getBounds());

                    L.marker(mapPoints[0]).addTo(rasekomap).bindPopup('Lähtö');
                    L.marker(mapPoints[mapPoints.length - 1]).addTo(rasekomap).bindPopup('Paluu');
                };

                loadRouteData();
            </script>
        </div>
    </div>
</body>