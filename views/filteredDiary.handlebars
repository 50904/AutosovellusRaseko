<div class="container">
    <h1>Hakuehdot täyttävät ajot</h1>
    <p>Seuraavasta taulukosta näkyy ajot valitsemillasi ehdoilla</p>

    <table>
        <tr>
            <th>Auto</th>
            <th>Kuljettaja</th>
            <th>Tarkoitus</th>
            <th>Lähtö</th>
            <th>Paluu</th>
        </tr>
        {{#each diaryData}}
        <tr>
            <td>{{rekisterinumero}}</td>
            <td>{{etunimi}} {{sukunimi}}</td>
            <td>{{tarkoitus}}</td>
            <td>{{otto}}</td>
            <td>{{palautus}}</td>
        </tr>
        {{/each}}
    </table>
</div>